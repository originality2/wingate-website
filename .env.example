# Contentful CMS Configuration
# Copy this file to .env and fill in your Contentful credentials.
# Sign up for free at https://www.contentful.com

# Your Contentful Space ID (found in Settings > API keys)
VITE_CONTENTFUL_SPACE_ID=your_space_id_here

# Your Contentful Content Delivery API access token
VITE_CONTENTFUL_ACCESS_TOKEN=your_access_token_here

# Optional: Contentful Preview API access token (for draft content)
# VITE_CONTENTFUL_PREVIEW_TOKEN=your_preview_token_here
